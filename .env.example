# Frontend API base URL
# - Local:  http://localhost:3000
# - Vercel: leave empty, requests '/api/...' will go through vercel.json rewrite
VITE_API_URL=

# Google OAuth (optional)
VITE_GOOGLE_CLIENT_ID=
VITE_ENABLE_GOOGLE_LOGIN=true

# Google Maps API key (optional if using address autocomplete/map)
VITE_GOOGLE_API_KEY=

# Optional: personal QR image URL for invoice page
VITE_PERSONAL_QR_IMAGE_URL=
